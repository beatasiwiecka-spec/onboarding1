<!-- LAUNCHED -->
<div class="section">
  <div class="section-title">✅ Launched Programs (2)</div>
  <table>
    <thead><tr><th>Customer</th><th>Phase</th><th>Contract Start</th><th>Expected Launch</th><th>TOM</th><th>CSM</th><th>Progress</th><th>Status</th><th>Timeline</th></tr></thead>
    <tbody>
      <tr data-tags="completed">
        <td class="name-cell">Project Papa</td>
        <td><span class="badge badge-completed">Completed</span></td>
        <td>—</td><td>—</td><td>—</td><td>—</td>
        <td><div class="progress-wrap"><div class="progress-fill done" style="width:100%"></div></div><span class="progress-text">100%</span></td>
        <td><span class="badge badge-completed">Launched</span></td>
        <td><span class="days-ok">Done</span></td>
      </tr>
      <tr data-tags="completed">
        <td class="name-cell">Project Mano Vino</td>
        <td><span class="badge badge-completed">Completed</span></td>
        <td>—</td><td>—</td><td>—</td><td>—</td>
        <td><div class="progress-wrap"><div class="progress-fill done" style="width:100%"></div></div><span class="progress-text">100%</span></td>
        <td><span class="badge badge-completed">Launched</span></td>
        <td><span class="days-ok">Done</span></td>
      </tr>
    </tbody>
  </table>
</div>

<script>
function filterRows(tag, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('tbody tr').forEach(row => {
    if (tag === 'all') { row.style.display = ''; }
    else {
      var tags = row.getAttribute('data-tags') || '';
      row.style.display = tags.includes(tag) ? '' : 'none';
    }
  });
}
</script>
</body>
</html>
