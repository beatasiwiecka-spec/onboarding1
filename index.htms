<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #f5f4f0; font-family: Arial, Helvetica, sans-serif; padding: 32px; }

  h1 { font-family: Georgia, serif; font-size: 28px; font-weight: 900; color: #0d1b3e; margin-bottom: 4px; }
  .subtitle { font-size: 12px; color: #888; margin-bottom: 24px; }

  .summary-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 24px; }
  .summary-card { background: #fff; border-radius: 4px; border: 1px solid #e0ddd8; padding: 14px 16px; text-align: center; }
  .summary-value { font-family: 'Barlow', sans-serif; font-size: 28px; font-weight: 900; color: #0d1b3e; }
  .summary-label { font-size: 10px; color: #888; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.06em; }
  .summary-card.danger .summary-value { color: #a32d2d; }
  .summary-card.success .summary-value { color: #2e7d32; }
  .summary-card.warning .summary-value { color: #e65100; }

  .legend { display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: #444; }
  .dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  .filter-row { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
  .filter-btn {
    padding: 5px 14px; border-radius: 20px; font-size: 11px; font-weight: 600;
    border: 1px solid #c0bbb2; background: #fff; color: #444; cursor: pointer;
  }
  .filter-btn.active { background: #0d1b3e; color: #fff; border-color: #0d1b3e; }
  .filter-btn:hover { background: #e8a0aa; color: #0d1b3e; border-color: #e8a0aa; }

  .section { margin-bottom: 28px; }
  .section-title {
    font-family: Arial, Helvetica, sans-serif; font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: #fff;
    background: #0d1b3e; padding: 8px 16px; border-radius: 2px; margin-bottom: 8px;
  }

  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  th {
    background: #eceae4; color: #0d1b3e; font-family: Arial, Helvetica, sans-serif;
    font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 8px 12px; text-align: left; border-bottom: 2px solid #d9d0c8;
  }
  td { padding: 9px 12px; border-bottom: 1px solid #e8e4df; color: #333; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #faf9f7; }

  .badge {
    display: inline-block; padding: 3px 10px; border-radius: 20px;
    font-size: 10px; font-weight: 700; white-space: nowrap;
  }
  .badge-overdue { background: #fde8e8; color: #a32d2d; }
  .badge-m1 { background: #e8f0fd; color: #1a3a7a; }
  .badge-m2 { background: #e8f4fd; color: #0d5a8a; }
  .badge-m3 { background: #f0e8fd; color: #5a1a8a; }
  .badge-completed { background: #e8f5e9; color: #2e7d32; }
  .badge-paused { background: #fff3e0; color: #e65100; }
  .badge-notstarted { background: #eceae4; color: #666; }
  .badge-ontrack { background: #e8f5e9; color: #2e7d32; }

  .days-overdue { font-size: 10px; color: #a32d2d; font-weight: 600; }
  .days-ok { font-size: 10px; color: #2e7d32; font-weight: 600; }
  .days-left { font-size: 10px; color: #888; }

  .name-cell { font-weight: 600; color: #0d1b3e; }

  .progress-wrap { background: #eceae4; border-radius: 10px; height: 6px; width: 80px; overflow: hidden; display: inline-block; vertical-align: middle; margin-right: 6px; }
  .progress-fill { height: 100%; border-radius: 10px; background: #0d1b3e; }
  .progress-fill.overdue { background: #a32d2d; }
  .progress-fill.done { background: #2e7d32; }
  .progress-text { font-size: 10px; color: #666; vertical-align: middle; }

  .update-badge {
    display: inline-block; background: #e8a0aa; color: #0d1b3e;
    font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 10px; margin-left: 6px;
  }
</style>
</head>
<body>

<h1>Onboarding Overview 2026</h1>
<p class="subtitle">Weekly update · TOM: Gailan Hart & Beata Rusin-Siwiecka · Updated: March 2026</p>

<div class="summary-row">
  <div class="summary-card danger">
    <div class="summary-value">17</div>
    <div class="summary-label">Overdue</div>
  </div>
  <div class="summary-card">
    <div class="summary-value">7</div>
    <div class="summary-label">On Track</div>
  </div>
  <div class="summary-card warning">
    <div class="summary-value">1</div>
    <div class="summary-label">Paused</div>
  </div>
  <div class="summary-card success">
    <div class="summary-value">2</div>
    <div class="summary-label">Launched</div>
  </div>
  <div class="summary-card">
    <div class="summary-value">27</div>
    <div class="summary-label">Total Projects</div>
  </div>
</div>

<div class="legend">
  <div class="legend-item"><div class="dot" style="background:#a32d2d"></div> Overdue</div>
  <div class="legend-item"><div class="dot" style="background:#1a3a7a"></div> M1: PDR/Planning</div>
  <div class="legend-item"><div class="dot" style="background:#0d5a8a"></div> M2: Implementation</div>
  <div class="legend-item"><div class="dot" style="background:#5a1a8a"></div> M3: UAT/Delivered</div>
  <div class="legend-item"><div class="dot" style="background:#2e7d32"></div> On Track / Completed</div>
  <div class="legend-item"><div class="dot" style="background:#e65100"></div> Paused</div>
  <div class="legend-item"><div class="dot" style="background:#e8a0aa"></div> New This Week</div>
</div>

<div class="filter-row">
  <button class="filter-btn active" onclick="filterRows('all', this)">All</button>
  <button class="filter-btn" onclick="filterRows('overdue', this)">🔴 Overdue</button>
  <button class="filter-btn" onclick="filterRows('m1', this)">M1</button>
  <button class="filter-btn" onclick="filterRows('m2', this)">M2</button>
  <button class="filter-btn" onclick="filterRows('m3', this)">M3</button>
  <button class="filter-btn" onclick="filterRows('ontrack', this)">✅ On Track</button>
  <button class="filter-btn" onclick="filterRows('new', this)">🆕 New</button>
</div>

<!-- UPCOMING -->
